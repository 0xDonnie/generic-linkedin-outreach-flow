node_modules/
.env
.env.local
.env.*.local

# Data outputs (may contain personal data — never commit)
data/raw/**/*.csv
data/raw/**/*.json
data/enriched/**/*.csv
data/enriched/**/*.json
data/campaigns/sent/**
data/campaigns/replies/**
data/campaigns/conversions/**

