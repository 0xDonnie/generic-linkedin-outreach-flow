# ─────────── Database ───────────
# Local: postgresql://postgres:PASSWORD@localhost:5432/DB_NAME
# VPS:   postgresql://USER:PASSWORD@localhost:5432/DB_NAME (dedicated user)
DATABASE_URL=

# ─────────── Enrichment APIs ───────────
HUNTER_IO_API_KEY=
APOLLO_API_KEY=
APOLLO_REVEAL_PERSONAL_EMAILS=false

# ─────────── LinkedIn ───────────
# We do NOT scrape LinkedIn. This is a path to a CSV export from Sales Navigator if used.
LINKEDIN_SALES_NAV_EXPORT_CSV=./data/raw/sales-navigator-export.csv

# ─────────── Email (SMTP via Brevo) ───────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─────────── Outbound domain (primary, used as reply-to address) ───────────
PRIMARY_OUTBOUND_DOMAIN=
# e.g., ba-compliance.com (one of your 5 outbound domains — the "canonical" one)

# Default sender email (used by scripts)
DEFAULT_FROM_ADDRESS=sales@${PRIMARY_OUTBOUND_DOMAIN}

# ─────────── Sender identity (used in email templates) ───────────
SENDER_FIRST_NAME=
SENDER_FULL_NAME=
SENDER_TITLE=
SENDER_COMPANY=
SENDER_CALENDAR_URL=

# ─────────── Product-specific content (filled from intake answers) ───────────
PRODUCT_CATEGORY=
PRODUCT_PITCH=
BENEFIT_1=
BENEFIT_2=
BENEFIT_3=
CLOSING_DIFFERENTIATOR=
LEGITIMATE_INTEREST_JUSTIFICATION=
HOOK_SUBJECT_TEMPLATE=

# ─────────── Compliance ───────────
COMPANY_LEGAL_NAME=
COMPANY_ADDRESS=
DPO_EMAIL=
UNSUBSCRIBE_BASE_URL=
PRIVACY_NOTICE_URL=

# ─────────── LIA (Legitimate Interest Assessment) ───────────
# Updated once the lawyer signs the LIA document.
LIA_REF=LIA-REPLACE-WITH-SIGNED-CODE-FROM-LAWYER

# ─────────── Cloudflare (for unsubscribe sync + DNS automation) ───────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_KV_NAMESPACE_ID=

# ─────────── Telegram notifications (if using Telegram) ───────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────── Slack notifications (if using Slack instead of Telegram) ───────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_REPLIES=#sales-replies
SLACK_CHANNEL_BOOKINGS=#sales-bookings

# ─────────── n8n (set in process env, not .env, for local mode — script handles) ───────────
N8N_HOST=n8n.${PRIMARY_OUTBOUND_DOMAIN}
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.${PRIMARY_OUTBOUND_DOMAIN}/
N8N_BASIC_AUTH_ACTIVE=false
# n8n 1.x uses UI-based owner account, not basic auth

# ─────────── n8n template loading (absolute path for the template loader in n8n function nodes) ───────────
TEMPLATE_DIR=
# Local Windows: D:/GitHub/YOUR-PROJECT/templates/email-templates
# VPS Linux:     /opt/YOUR-PROJECT/templates/email-templates

# ─────────── Rate Limiting ───────────
REQUESTS_PER_MINUTE=10
DAILY_EMAIL_LIMIT=50
SCRAPER_DELAY_MS=3000

# ─────────── Active campaign (set after creating in DB) ───────────
ACTIVE_CAMPAIGN_ID=

# ─────────── Logging ───────────
LOG_LEVEL=info
LOG_DIR=./logs
