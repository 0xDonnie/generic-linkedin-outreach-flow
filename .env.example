# ─────────── Database ───────────
# Local: postgresql://postgres:PASSWORD@localhost:5432/DB_NAME
# VPS:   postgresql://USER:PASSWORD@localhost:5432/DB_NAME (dedicated user)
DATABASE_URL=

# ─────────── Enrichment APIs ───────────
# Apollo is primary — gives us LinkedIn URLs directly alongside email/phone
APOLLO_API_KEY=
APOLLO_REVEAL_PERSONAL_EMAILS=false
# Hunter is optional (email verification). Usually not needed for LinkedIn-only outreach.
HUNTER_IO_API_KEY=

# ─────────── LinkedIn Engine ───────────
# Which engine drives the actual LinkedIn sends. Picked at intake based on account status.
# Values: heyreach | linkedhelper
LINKEDIN_ENGINE=heyreach

# --- Engine A: HeyReach (cloud API, for established accounts) ---
HEYREACH_API_KEY=
HEYREACH_ACCOUNT_ID=
# Webhook URL that HeyReach calls when a reply / connection acceptance happens.
# Set to your n8n webhook after deploying workflow 3 (reply-handler).
HEYREACH_WEBHOOK_URL=

# --- Engine B: LinkedHelper 2 (local Chrome extension) ---
# LinkedHelper exposes a local HTTP server for integration. Default 127.0.0.1:7337.
LINKEDHELPER_LOCAL_URL=http://127.0.0.1:7337
# API key you set in LinkedHelper settings (Tools -> HTTP API).
LINKEDHELPER_API_KEY=
# Profile URL of the LinkedIn account LinkedHelper is driving (for logging + audit).
LINKEDHELPER_SENDER_PROFILE_URL=

# ─────────── Sender identity (used in message templates) ───────────
SENDER_FIRST_NAME=
SENDER_FULL_NAME=
SENDER_TITLE=
SENDER_COMPANY=
SENDER_CALENDAR_URL=
# The LinkedIn profile URL the recipient will see as sender.
SENDER_LINKEDIN_URL=

# ─────────── Product-specific content (filled from intake answers) ───────────
PRODUCT_CATEGORY=
PRODUCT_PITCH=
BENEFIT_1=
BENEFIT_2=
BENEFIT_3=
CLOSING_DIFFERENTIATOR=
LEGITIMATE_INTEREST_JUSTIFICATION=
# Connection-note hook (max ~250 chars including name)
CONNECTION_NOTE_HOOK=
# First-DM opener — single sentence
FIRST_MESSAGE_HOOK=

# ─────────── Compliance ───────────
COMPANY_LEGAL_NAME=
COMPANY_ADDRESS=
DPO_EMAIL=
# Public landing page URL for privacy notice + opt-out form (Cloudflare Pages)
PRIVACY_NOTICE_URL=
OPTOUT_FORM_URL=

# ─────────── LIA (Legitimate Interest Assessment) ───────────
# Updated once the lawyer signs the LIA document.
LIA_REF=LIA-REPLACE-WITH-SIGNED-CODE-FROM-LAWYER

# ─────────── Cloudflare (for privacy notice page + opt-out sync) ───────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_PAGES_PROJECT_NAME=

# ─────────── Telegram notifications (if using Telegram) ───────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────── Slack notifications (if using Slack instead of Telegram) ───────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_REPLIES=#sales-replies
SLACK_CHANNEL_BOOKINGS=#sales-bookings

# ─────────── Cal.com ───────────
CAL_COM_API_KEY=
CAL_COM_WEBHOOK_SECRET=
CAL_COM_BOOKING_URL=

# ─────────── n8n ───────────
# Local: http://localhost:5678  |  VPS: https://n8n.your-domain.com
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=false
# n8n 1.x uses UI-based owner account, not basic auth

# ─────────── n8n template loading (absolute path for template loader in Function nodes) ───────────
TEMPLATE_DIR=
# Local Windows: D:/GitHub/YOUR-PROJECT/templates/linkedin-templates
# VPS Linux:     /opt/YOUR-PROJECT/templates/linkedin-templates

# ─────────── Rate Limiting (LinkedIn-specific, STRICT) ───────────
# LinkedIn's 2024-2025 sustainable caps. Do not raise unless you accept ban risk.
DAILY_LI_CONNECTION_LIMIT=20
DAILY_LI_MESSAGE_LIMIT=40
WEEKLY_LI_CONNECTION_LIMIT=100
# Jitter (ms) between actions — humanize
ACTION_JITTER_MIN_MS=45000
ACTION_JITTER_MAX_MS=180000
# Active sending hours (user's local TZ, 24h)
SEND_HOUR_START=9
SEND_HOUR_END=18

# ─────────── Warmup state (managed by workflows) ───────────
# Current day of warmup ramp (0 = not started, 1..21 = ramping, 22+ = cruising)
WARMUP_DAY=0

# ─────────── Active campaign (set after creating in DB) ───────────
ACTIVE_CAMPAIGN_ID=

# ─────────── Logging ───────────
LOG_LEVEL=info
LOG_DIR=./logs
