{
  "name": "generic-linkedin-outreach-flow",
  "version": "1.0.0",
  "description": "Turnkey B2B LinkedIn cold outreach framework — dual engine (HeyReach for established accounts, LinkedHelper 2 for new accounts), GDPR-compliant, multi-deployment, with Apollo + n8n + Cloudflare + Cal.com + Telegram/Slack + Otter",
  "type": "module",
  "private": true,
  "scripts": {
    "db:setup": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "crm:load": "node scripts/node/load-crm.mjs",
    "li:test": "node scripts/node/test-linkedin-send.mjs",
    "li:dry-run": "node scripts/node/test-linkedin-send.mjs --dry-run",
    "kpi": "node scripts/node/kpi.mjs",
    "dashboard:up": "docker compose -f dashboards/metabase/docker-compose.yml up -d",
    "dashboard:down": "docker compose -f dashboards/metabase/docker-compose.yml down",
    "dashboard:logs": "docker compose -f dashboards/metabase/docker-compose.yml logs -f"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0-rc.12",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.0",
    "pg": "^8.11.0",
    "playwright": "^1.44.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
