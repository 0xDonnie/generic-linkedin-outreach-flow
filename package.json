{
  "name": "generic-coldmailing-flow",
  "version": "1.0.0",
  "description": "Turnkey B2B/B2C cold email outbound framework — GDPR-compliant, multi-deployment (local or VPS), with Apollo + Brevo + n8n + Cloudflare + Cal.com + Telegram/Slack + Otter",
  "type": "module",
  "private": true,
  "scripts": {
    "db:setup": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "crm:load": "node scripts/node/load-crm.mjs",
    "send:test": "node scripts/node/test-send-one.mjs",
    "send:dry-run": "node scripts/node/test-send-one.mjs --dry-run",
    "sync:unsubscribes": "node scripts/node/sync-unsubscribes.mjs"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0-rc.12",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.0",
    "email-validator": "^2.0.4",
    "nodemailer": "^6.9.16",
    "pg": "^8.11.0",
    "playwright": "^1.44.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
